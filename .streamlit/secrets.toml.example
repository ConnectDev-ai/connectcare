# ============================================================
# Streamlit secrets — desarrollo local
# En Streamlit Community Cloud: Settings → Secrets → pegar este contenido
# ============================================================

# Connection string de Supabase
# Obtener en: Supabase → Settings → Database → Connection string → URI
# IMPORTANTE: cambiar "postgresql://" por "postgresql+psycopg://"
DATABASE_URL = "postgresql+psycopg://postgres:[PASSWORD]@db.XXXX.supabase.co:5432/postgres?sslmode=require"
