# ── Base de datos (Neon PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://user:password@host/dbname

# ── Copiloto API ──────────────────────────────────────────────────────────────
COPILOTO_API_TOKEN=
COPILOTO_EMAIL=
COPILOTO_PASSWORD=
COPILOTO_ENDPOINT=

# ── Geotab ────────────────────────────────────────────────────────────────────
GEOTAB_DATABASES=divemotor_colombia,divemotor,divemotor_buses
GEOTAB_USERNAME=
GEOTAB_PASSWORD=
GEOTAB_SERVER=my.geotab.com

# ── Supabase (auth) ───────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ── Tickets ───────────────────────────────────────────────────────────────────
TICKET_MANAGERS=ejecutivo@empresa.com
TICKET_SLA_DAYS=5

# ── Next.js → Flask proxy ─────────────────────────────────────────────────────
# URL pública del backend Flask (Render, Railway, etc.)
# En desarrollo local dejar en blanco (usa http://localhost:5000)
FLASK_API_URL=https://tu-api.onrender.com
